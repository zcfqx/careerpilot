<view class="login-page">
  <view class="login-bg">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
    <view class="bg-circle bg-circle-3"></view>
  </view>

  <view class="login-content">
    <view class="logo-section">
      <view class="logo-icon">
        <text class="logo-emoji">🎯</text>
      </view>
      <text class="app-title">AI韧性职业适配</text>
      <text class="app-subtitle">数据驱动 · AI赋能 · 精准匹配</text>
    </view>

    <view class="login-card">
      <view class="card-header">
        <text class="card-title">欢迎使用</text>
        <text class="card-desc">登录后即可体验AI智能职业评估</text>
      </view>

      <view class="features-list">
        <view class="feature-item">
          <text class="feature-icon">🤖</text>
          <text class="feature-text">AI智能评估</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">📊</text>
          <text class="feature-text">数据趋势分析</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">🎯</text>
          <text class="feature-text">精准职业匹配</text>
        </view>
      </view>

      <button class="login-btn" bindtap="handleLogin" disabled="{{logging}}">
        <text class="btn-icon" wx:if="{{!logging}}">💬</text>
        <view class="loading-spinner" wx:if="{{logging}}"></view>
        <text class="btn-text">{{logging ? '登录中...' : '微信一键登录'}}</text>
      </button>

      <view class="login-hint">
        <text class="hint-text">登录即表示同意</text>
        <text class="hint-link">《用户协议》</text>
        <text class="hint-text">和</text>
        <text class="hint-link">《隐私政策》</text>
      </view>
    </view>

    <view class="version-info">
      <text class="version-text">AI韧性职业适配系统 v1.0</text>
    </view>
  </view>
</view>
