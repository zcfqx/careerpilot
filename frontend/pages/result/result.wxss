.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

.score-card {
  text-align: center;
  padding: 40rpx 32rpx;
}

.score-title {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 12rpx solid #1890ff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
}

.score-number {
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1;
}

.score-unit {
  font-size: 24rpx;
  color: #999;
}

.dimension-list {
  text-align: left;
}

.dimension-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.dim-label {
  width: 120rpx;
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

.dim-bar-wrap {
  flex: 1;
  height: 12rpx;
  background-color: #f0f0f0;
  border-radius: 6rpx;
  margin: 0 16rpx;
}

.dim-bar {
  height: 100%;
  border-radius: 6rpx;
}

.dim-value {
  width: 60rpx;
  font-size: 24rpx;
  color: #333;
  text-align: right;
}

.job-tabs {
  display: flex;
  overflow-x: auto;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding-bottom: 8rpx;
}

.job-tab {
  padding: 12rpx 24rpx;
  background-color: #f5f6fa;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
  flex-shrink: 0;
}

.job-tab.active {
  background-color: #1890ff;
  color: #ffffff;
}

.match-score-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.match-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 16rpx;
}

.match-score {
  font-size: 48rpx;
  font-weight: 700;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.reason-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

.reason-dot {
  color: #1890ff;
  margin-right: 12rpx;
  font-size: 20rpx;
  margin-top: 8rpx;
}

.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.gap-tag {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.skill-tag {
  background-color: #fff7e6;
  color: #fa8c16;
}

.ability-tag {
  background-color: #f0f5ff;
  color: #2f54eb;
}

.action-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.action-btns .btn-primary,
.action-btns .btn-secondary {
  flex: 1;
}

.generating-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeInMask 0.3s ease;
}

@keyframes fadeInMask {
  from { opacity: 0; }
  to { opacity: 1; }
}

.generating-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 48rpx;
  width: 80%;
  max-width: 600rpx;
  text-align: center;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(60rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.generating-icon-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 32rpx;
}

.ai-icon {
  font-size: 72rpx;
  position: relative;
  z-index: 1;
  line-height: 120rpx;
}

.ai-pulse {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: rgba(24, 144, 255, 0.15);
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.3); opacity: 0.5; }
  100% { transform: scale(1); opacity: 1; }
}

.generating-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

.generating-step {
  font-size: 28rpx;
  color: #1890ff;
  margin-bottom: 32rpx;
  min-height: 40rpx;
}

.progress-bar-wrap {
  height: 12rpx;
  background-color: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #1890ff, #36cfc9);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.progress-percent {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.generating-hint {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.data-flow {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.flow-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #1890ff;
  animation: flowBounce 1.2s ease-in-out infinite;
}

@keyframes flowBounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}
