.loading-wrap {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 32rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  color: #666;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 40rpx;
}

.btn-row {
  display: flex;
  gap: 24rpx;
}

.retry-btn {
  background-color: #1890ff;
  color: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  border: none;
}

.retry-btn::after {
  border: none;
}

.back-btn {
  background-color: #f5f5f5;
  color: #666;
  border-radius: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  border: none;
}

.back-btn::after {
  border: none;
}

.summary-card {
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  color: #ffffff;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.summary-row {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-num {
  font-size: 44rpx;
  font-weight: 700;
}

.summary-label {
  font-size: 22rpx;
  opacity: 0.85;
}

.skill-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.priority-tag {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.priority-high {
  background-color: #fff1f0;
  color: #ff4d4f;
}

.priority-medium {
  background-color: #fff7e6;
  color: #fa8c16;
}

.priority-low {
  background-color: #f0f5ff;
  color: #2f54eb;
}

.skill-level {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.suggested-hours {
  font-size: 24rpx;
  color: #1890ff;
  margin-top: 8rpx;
}

.course-item {
  padding: 16rpx;
  background-color: #f5f6fa;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.course-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.course-meta {
  display: flex;
  gap: 24rpx;
}

.course-platform, .course-duration {
  font-size: 22rpx;
  color: #999;
}

.tool-item {
  padding: 16rpx;
  background-color: #f0f5ff;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.tool-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.tool-practice {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}
