.tab-bar {
  display: flex;
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1890ff;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background-color: #1890ff;
  border-radius: 3rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  color: #666;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  color: #999;
  font-size: 24rpx;
  margin-bottom: 32rpx;
}

.refresh-btn {
  background-color: #1890ff;
  color: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  border: none;
  margin-top: 16rpx;
}

.refresh-btn::after {
  border: none;
}

.trend-chart {
  display: flex;
  align-items: flex-end;
  height: 300rpx;
  padding: 16rpx 0;
  gap: 8rpx;
}

.trend-bar-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  justify-content: flex-end;
}

.trend-bar {
  width: 100%;
  background: linear-gradient(180deg, #1890ff, #36cfc9);
  border-radius: 4rpx 4rpx 0 0;
  min-height: 8rpx;
}

.trend-date {
  font-size: 18rpx;
  color: #999;
  margin-top: 8rpx;
  transform: rotate(-30deg);
  white-space: nowrap;
}

.skill-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  padding: 24rpx;
}

.cloud-tag {
  padding: 8rpx 20rpx;
  background-color: #e6f7ff;
  color: #1890ff;
  border-radius: 8rpx;
  font-weight: 500;
}

.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.search-btn {
  background-color: #1890ff;
  color: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  border: none;
}

.search-btn::after {
  border: none;
}

.job-card {
  padding: 24rpx;
}

.job-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.job-salary {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: 600;
}

.job-company {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

.job-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.job-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.job-tag {
  padding: 4rpx 12rpx;
  background-color: #f0f5ff;
  color: #1890ff;
  border-radius: 6rpx;
  font-size: 22rpx;
}
