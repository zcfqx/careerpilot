.loading-wrap {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #722ed1;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

.plan-header {
  background: linear-gradient(135deg, #722ed1, #b37feb);
  color: #ffffff;
  text-align: center;
  padding: 40rpx 32rpx;
}

.plan-job {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.plan-subtitle {
  font-size: 24rpx;
  opacity: 0.85;
}

.goal-list {
  margin-bottom: 8rpx;
}

.goal-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.goal-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.goal-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.milestone-list {
  position: relative;
}

.milestone-item {
  display: flex;
  align-items: flex-start;
  position: relative;
  padding-bottom: 24rpx;
}

.milestone-item:last-child {
  padding-bottom: 0;
}

.milestone-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #1890ff;
  flex-shrink: 0;
  margin-top: 8rpx;
  margin-right: 16rpx;
  z-index: 1;
}

.milestone-dot.mid {
  background-color: #722ed1;
}

.milestone-line {
  position: absolute;
  left: 9rpx;
  top: 28rpx;
  width: 2rpx;
  height: calc(100% - 28rpx);
  background-color: #e8e8e8;
}

.milestone-item:last-child .milestone-line {
  display: none;
}

.milestone-content {
  flex: 1;
}

.milestone-time {
  font-size: 24rpx;
  color: #1890ff;
  font-weight: 600;
  display: block;
  margin-bottom: 4rpx;
}

.milestone-desc {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

.plan-input {
  padding: 20rpx 24rpx;
  background-color: #f5f6fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.plan-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.plan-item:last-child {
  border-bottom: none;
}

.plan-item-info {
  flex: 1;
}

.plan-item-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.plan-item-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.plan-item-arrow {
  font-size: 36rpx;
  color: #ccc;
  flex-shrink: 0;
}

.btn-group {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
  padding-bottom: 60rpx;
}

.btn-group .btn-primary,
.btn-group .btn-secondary {
  flex: 1;
}

.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  color: #666;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  color: #999;
  font-size: 24rpx;
}

.refresh-btn {
  background-color: #1890ff;
  color: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  border: none;
  margin-top: 32rpx;
}

.refresh-btn::after {
  border: none;
}

.generating-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeInMask 0.3s ease;
}

@keyframes fadeInMask {
  from { opacity: 0; }
  to { opacity: 1; }
}

.generating-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 48rpx;
  width: 80%;
  max-width: 600rpx;
  text-align: center;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(60rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.generating-icon-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 32rpx;
}

.ai-icon {
  font-size: 72rpx;
  position: relative;
  z-index: 1;
  line-height: 120rpx;
}

.ai-pulse {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: rgba(114, 46, 209, 0.15);
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.3); opacity: 0.5; }
  100% { transform: scale(1); opacity: 1; }
}

.generating-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

.generating-step {
  font-size: 28rpx;
  color: #722ed1;
  margin-bottom: 32rpx;
  min-height: 40rpx;
}

.progress-bar-wrap {
  height: 12rpx;
  background-color: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #722ed1, #b37feb);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.progress-percent {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.generating-hint {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.data-flow {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.flow-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #722ed1;
  animation: flowBounce 1.2s ease-in-out infinite;
}

@keyframes flowBounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}
